# ─── Server Session ───────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production

# ─── Vision Provider ──────────────────────────────────────────────────────────
# Which AI provider to use for frame analysis.
# Options: simulation | openai | gemini | local
# Default: simulation (no API key required)
VISION_PROVIDER=simulation

# OpenAI API key — required only when VISION_PROVIDER=openai.
# Uses gpt-4o with vision. Server-side only; NEVER exposed to the browser.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API key — required only when VISION_PROVIDER=gemini (Phase 5).
# GEMINI_API_KEY=

# Local vision endpoint — required only when VISION_PROVIDER=local (Phase 5).
# Example: http://localhost:11434/api/generate (Ollama + LLaVA)
# LOCAL_VISION_ENDPOINT=

# ─── Safety Constraints ───────────────────────────────────────────────────────
# These are always false — changing them has no effect.
# They exist to make the safety posture explicit in code review.
FACE_RECOGNITION_ENABLED=false
EMERGENCY_STREAMING_ENABLED=false

# ─── Database (Phase 5) ───────────────────────────────────────────────────────
# DATABASE_URL=file:./dev.db
